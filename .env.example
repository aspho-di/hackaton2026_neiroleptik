# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/irrigation_db

# Пример для Docker:
# DATABASE_URL=postgresql://postgres:password@db:5432/irrigation_db

# ── Сервис прогноза погоды (первый ML-разработчик) ───────────────────────────
FORECAST_SERVICE_URL=http://localhost:8001/predict/forecast
